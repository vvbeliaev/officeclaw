DATABASE_URL=postgresql://officeclaw:officeclaw@localhost:5432/officeclaw
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
DEBUG=false

# Sandbox runner: "docker" for local dev, "msb" for production (microsandbox
# Python SDK — Linux x86_64/aarch64 or macOS arm64 + KVM). The "msb" runner
# requires installing the optional `microsandbox` extra:
#   pip install -e "./api[microsandbox]"
SANDBOX_RUNNER=docker
# Host to reach nanobot gateway: "localhost" when API runs natively,
# "host.docker.internal" when API runs inside Docker (compose)
SANDBOX_GATEWAY_HOST=localhost
# Where sandbox workspaces are materialised on the host. Must be a path
# that the sandbox runner can bind-mount. Default is <repo>/.sandboxes
# (git-ignored, visible in IDE). On macOS with Docker Desktop, /tmp is
# NOT in the file-sharing list — stick with the default or another path
# under /Users.
# SANDBOX_WORKDIR=./.sandboxes

# ── Default LLM (OpenAI-compatible endpoint) ─────────────────────────
# Seeded into a "default-llm" user env on every user bootstrap and
# injected into every agent sandbox as environment variables. Nanobot
# resolves ${OFFICECLAW_LLM_*} from these vars, so secrets never land
# in config.json on disk.
# Works with any OpenAI-compatible provider: OpenAI, OpenRouter,
# DeepSeek, Together, Groq, vLLM, Ollama, etc.
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
DEFAULT_LLM_MODEL=gpt-4o-mini

# ── Default web search (nanobot tools.web.search) ────────────────────
# Seeded into a per-workspace "default-web-search" env on bootstrap and
# injected into every agent sandbox. Nanobot resolves
# ${OFFICECLAW_WEB_SEARCH_*} from these vars.
# Providers: duckduckgo (no key), brave, tavily, searxng, jina.
DEFAULT_WEB_SEARCH_PROVIDER=duckduckgo
DEFAULT_WEB_SEARCH_API_KEY=

# ── Knowledge Graph (LightRAG) ────────────────────────────────────────
# LLM for knowledge graph operations (entity/relationship extraction)
KNOWLEDGE_LLM_API_KEY=
KNOWLEDGE_LLM_BASE_URL=https://api.openai.com/v1
KNOWLEDGE_LLM_MODEL=gpt-4o-mini
# Embedding model for knowledge graph vectors
KNOWLEDGE_EMBED_API_KEY=
KNOWLEDGE_EMBED_BASE_URL=https://api.openai.com/v1
KNOWLEDGE_EMBED_MODEL=text-embedding-3-small
KNOWLEDGE_EMBED_DIM=1536

# ── Document normalisation (docling-serve) ────────────────────────────
# URL of the docling-serve instance. In Docker Compose this is set via
# the environment block and points to the docling service on the internal
# network. Override here only when running the API outside of compose.
DOCLING_URL=http://localhost:5001
